# Wet Nose Weather — bootstrap configuration
#
# Copy this file to wetnose.env and edit. It is read at startup by
#   - python app.py            (dev / single-process)
#   - the gunicorn systemd unit (production), via EnvironmentFile=
# Same syntax as systemd EnvironmentFile: KEY=VALUE per line, no export,
# comments with #. Existing environment variables take precedence over
# values in this file.

# Bind address. Keep 127.0.0.1 and put nginx/Caddy in front for LAN access.
WETNOSE_HOST=127.0.0.1

# Port. Must be 1-65535.
WETNOSE_PORT=5100

# Flask debug mode. 1/true/yes enables. NEVER enable in production.
WETNOSE_DEBUG=0

# Flask SECRET_KEY. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to auto-generate a new key on every process start (sessions
# will not survive restarts).
WETNOSE_SECRET_KEY=
